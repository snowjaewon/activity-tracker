# 이 파일을 secrets.toml 로 복사한 뒤 값을 채우세요. (secrets.toml은 git에 안 올라감)
# 서비스 계정 JSON 키 파일의 값들을 그대로 옮겨 적으면 됩니다.

[connections.gsheets]
spreadsheet = "https://docs.google.com/spreadsheets/d/여기에_시트ID/edit"
worksheet = "activities"
type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\n줄바꿈은_백슬래시n으로\n-----END PRIVATE KEY-----\n"
client_email = "tracker-bot@your-project-id.iam.gserviceaccount.com"
client_id = "1234567890"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/..."
